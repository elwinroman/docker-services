# Puertos publicados en host
GRAFANA_PORT=4000
PROMETHEUS_PORT=9090
VICTORIAMETRICS_PORT=8428
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318

# Configuración de Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=p@ssw0rd
GF_USERS_ALLOW_SIGN_UP=false

## Configuración de SMTP
GF_SMTP_ENABLED=true
GF_SMTP_HOST=example.com:465
GF_SMTP_USER=grafana_no_reply@example.com
GF_SMTP_PASSWORD=mipasscorreo
GF_SMTP_FROM_ADDRESS=grafana_no_reply@correo.com
GF_SMTP_FROM_NAME=Grafana CDD
# GF_SERVER_ROOT_URL=%(protocol)s://%(domain)s/grafana/
# GF_SERVER_SERVE_FROM_SUB_PATH=true

# Retención
# Loki/Tempo usan duración tipo 720h. Prometheus usa duración tipo 15d.
# VictoriaMetrics sin sufijo usa meses; 12 equivale a 12 meses.
LOKI_RETENTION_PERIOD=720h
LOKI_MAX_QUERY_LOOKBACK=720h
PROMETHEUS_RETENTION=15d
VICTORIAMETRICS_RETENTION=12
TEMPO_TRACE_RETENTION=168h
